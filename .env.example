LOVENSE_DEV_TOKEN="tk..."
# At least 32 characters (PyJWT/RFC 7518); same value for Next.js and bridge. Required in production.
JWT_SECRET="your-256-bit-secret-here-min-32-chars"
# Set to "true" to enable local test peer during npm run preview (dev only)
ALLOW_TEST_PEER="true"
# Optional: external partner bridge server URL. When empty, partner mode
# is disabled and the "Play with a partner" button is greyed out.
NEXT_PUBLIC_BRIDGE_SERVER_URL=""
ALLOW_SELF_PAIRING=0

# --- Bridge server (python -m bridge) ---
# Production: set BRIDGE_ENV=production (enforces JWT_SECRET, safe error messages)
# BRIDGE_ENV=production
# CORS: comma-separated origins, e.g. https://app.example.com,https://www.example.com
# Empty in production = no CORS. In dev, empty = allow *.
# CORS_ORIGINS=https://your-frontend.com
